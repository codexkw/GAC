@model GAC.Core.Content.CostOfServicePage
@{
    Layout = "_Layout";
    var p = Model;
    Func<string?, List<string>> lines = s =>
        (s ?? "").Split('\n').Select(x => x.Trim()).Where(x => x.Length > 0).ToList();
    var footer = lines(p.FooterNote.Localize());
    // Only emit the policy button for safe schemes (http/https or a relative/anchor path),
    // so an admin-supplied javascript:/data: URL can't become a clickable script on the page.
    var btnUrl = (p.ButtonUrl ?? "").Trim();
    var btnSafe = btnUrl.Length > 0 && (btnUrl.StartsWith("/") || btnUrl.StartsWith("#")
        || btnUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
        || btnUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase));
}

<div class="crumb-bar">
  <div class="container">
    <a class="crumb-back" href="/"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg> @L["Back"]</a>
    <nav class="crumb-trail">@L["You are here:"] <a href="/">@L["Homepage"]</a> <span>&gt;</span> <a href="/book-a-service">@L["Owners"]</a> <span>&gt;</span> @p.Title.Localize()</nav>
  </div>
</div>

<section class="section cos-head">
  <div class="container">
    <h1>@p.Title.Localize()</h1>
@if (btnSafe)
{
    <a class="btn btn--hero cos-policy-btn" href="@btnUrl" target="_blank" rel="noopener">@p.ButtonLabel.Localize()</a>
}
    <div class="datatable-wrap">
      <table class="datatable">
        <thead>
          <tr>
            <th>@p.TableHeadLabel.Localize()</th>
@foreach (var m in p.Models)
{
            <th>@m.Name</th>
}
          </tr>
        </thead>
        <tbody>
@for (var i = 0; i < p.Rows.Count; i++)
{
          <tr>
            <td>@p.Rows[i].Label.Localize()</td>
@foreach (var m in p.Models)
{
            <td>@(m.Cells.ElementAtOrDefault(i)?.Value)</td>
}
          </tr>
}
        </tbody>
      </table>
    </div>
@if (footer.Count > 0)
{
    <p class="note cos-note" style="margin-top:var(--space-5)">
@for (var k = 0; k < footer.Count; k++)
{
@footer[k]
if (k < footer.Count - 1)
{
<text><br /></text>
}
}
    </p>
}
  </div>
</section>
