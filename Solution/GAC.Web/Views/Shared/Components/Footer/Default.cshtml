@using GAC.Web.Infrastructure
@model GAC.Core.Content.SiteSettings

<!-- Fixed quick-action dock (right rail on desktop, bottom bar on mobile) — injected on every page via this footer partial -->
<nav class="action-dock" aria-label="Quick actions">
  <a class="action-dock__item action-dock__item--wa" href="https://api.whatsapp.com/send/?phone=@Model.WhatsApp" target="_blank" rel="noopener" title="Chat on WhatsApp" aria-label="Chat with us on WhatsApp">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.4 5 5.1-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20zm4.4-5.6c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.1-.3.2-.5 0-.7-.3-1.4-.6-2-1.2-.5-.5-.9-1.1-1.2-1.7-.1-.2 0-.4.1-.5l.4-.5c.1-.1.1-.3.2-.4 0-.2 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.4.1-.6.3-.6.6-.9 1.4-.9 2.2.1 1 .5 1.9 1.1 2.7.9 1.3 2 2.3 3.4 2.9.5.2.9.3 1.3.4.5.1 1 .1 1.4 0 .5-.1 1.4-.6 1.6-1.2.2-.5.2-1 .1-1.1z"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Chat on WhatsApp"]</span><span class="action-dock__short">@L["WhatsApp"]</span></span>
  </a>
  <a class="action-dock__item" href="/book-a-test-drive" title="Book a Test Drive">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13l2-5a2 2 0 0 1 1.9-1.3h10.2A2 2 0 0 1 19 8l2 5"/><path d="M3 13h18v4a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1H7v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/><path d="M6.5 15.5h.01M17.5 15.5h.01"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Book a Test Drive"]</span><span class="action-dock__short">@L["Test Drive"]</span></span>
  </a>
  <a class="action-dock__item" href="/request-a-quote" title="Get Online Quote">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h4"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Get Online Quote"]</span><span class="action-dock__short">@L["Quote"]</span></span>
  </a>
  <a class="action-dock__item" href="#" title="Download Brochure">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Download Brochure"]</span><span class="action-dock__short">@L["Brochure"]</span></span>
  </a>
  <a class="action-dock__item" href="/contact-us" title="Find Showroom">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Find Showroom"]</span><span class="action-dock__short">@L["Showroom"]</span></span>
  </a>
  <a class="action-dock__item" href="/contact-us" title="Contact Us">
    <span class="action-dock__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 6.5 8.5 6 8.5-6"/></svg></span>
    <span class="action-dock__text"><span class="action-dock__full">@L["Contact Us"]</span><span class="action-dock__short">@L["Contact"]</span></span>
  </a>
</nav>

<footer class="site-footer">
  <div class="container">
    <div class="footer-links">
      <div class="footer-left">
        <nav>
          <a title="Privacy Notice" href="/privacy-policy">@L["Privacy Notice"]</a>
          <a title="Site Map" href="#">@L["Site Map"]</a>
          <a title="About Us" href="/about">@L["About Us"]</a>
          <a title="Contact Us" href="/contact-us">@L["Contact Us"]</a>
          <a title="Suggestions &amp; Complaints" href="#">@L["Suggestions & Complaints"]</a>
        </nav>
        <a class="footer-totop" href="#page-wrap">@L["Back to Top"]</a>
      </div>
      <div class="footer-socials">
        @if (Model.InstagramUrl != null)
        {
