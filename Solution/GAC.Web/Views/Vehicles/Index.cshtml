@model IReadOnlyList<GAC.Core.Content.Vehicle>
@{
    ViewData["Title"] = "Models";
    ViewData["MetaDescription"] = "Explore the full 2026 GAC Motor lineup in Kuwait: SUVs, sedans and electric vehicles.";
}

  <section class="page-hero">
    <div class="container">
      <nav class="crumbs"><a href="/">Home</a><span>/</span>Models</nav>
      <h1>The Lineup</h1>
      <p style="max-width:60ch;color:rgba(255,255,255,.75)">SUVs, sedans and pure-electric powertrains. Use the filters to narrow by body type.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" data-filter-root>
      <div class="filters">
        <button class="chip is-active" data-filter="all">All</button>
        <button class="chip" data-filter="sedan">Sedans</button>
        <button class="chip" data-filter="suv">SUVs</button>
        <button class="chip" data-filter="ev">Electric</button>
      </div>

      <div class="model-grid">
@foreach (var v in Model)
{
        <div class="lineup-card" data-cat="@UrlHelpers.CategoryCss(v.Category)"><a class="lineup-card__media" href="/@v.Slug" aria-label="View details"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></a><div class="lineup-card__body"><div class="lineup-card__name">@v.Name.Localize()</div><div class="lineup-card__tag">@v.Tagline.Localize()</div><div class="lineup-card__actions"><a class="btn btn--accent" href="/@v.Slug">Explore</a><a class="btn btn--ghost" href="/request-a-quote">Quote</a></div></div></div>
}
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container">
      <h2>Not sure which model?</h2>
      <p>Book a test drive or talk to a GAC product specialist and we'll help you compare the range.</p>
      <a class="btn" href="/book-a-test-drive">Book a Test Drive</a>
    </div>
  </section>
