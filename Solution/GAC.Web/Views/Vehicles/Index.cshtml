@model IReadOnlyList<GAC.Core.Content.Vehicle>
@{
    ViewData["Title"] = "Models";
    ViewData["MetaDescription"] = "Explore the full 2026 GAC Motor lineup in Kuwait: SUVs, sedans and electric vehicles.";
}

  <section class="page-hero">
    <div class="container">
      <nav class="crumbs"><a href="/">@L["Home"]</a><span>/</span>@L["Models"]</nav>
      <h1>@L["The Lineup"]</h1>
      <p style="max-width:60ch;color:rgba(255,255,255,.75)">@L["SUVs, sedans and pure-electric powertrains. Use the filters to narrow by body type."]</p>
    </div>
  </section>

  <section class="section">
    <div class="container" data-filter-root>
      <div class="filters">
        <button class="chip is-active" data-filter="all">@L["All"]</button>
        <button class="chip" data-filter="sedan">@L["Sedans"]</button>
        <button class="chip" data-filter="suv">@L["SUVs"]</button>
        <button class="chip" data-filter="ev">@L["Electric"]</button>
      </div>

      <div class="model-grid">
@foreach (var v in Model)
{
        <div class="lineup-card" data-cat="@UrlHelpers.CategoryCss(v.Category)"><a class="lineup-card__media" href="/@v.Slug" aria-label="View details"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></a><div class="lineup-card__body"><div class="lineup-card__name">@v.Name.Localize()</div><div class="lineup-card__tag">@v.Tagline.Localize()</div><div class="lineup-card__actions"><a class="btn btn--accent" href="/@v.Slug">@L["Explore"]</a><a class="btn btn--ghost" href="/request-a-quote">@L["Quote"]</a></div></div></div>
}
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container">
      <h2>@L["Not sure which model?"]</h2>
      <p>@L["Book a test drive or talk to a GAC product specialist and we'll help you compare the range."]</p>
      <a class="btn" href="/book-a-test-drive">@L["Book a Test Drive"]</a>
    </div>
  </section>
