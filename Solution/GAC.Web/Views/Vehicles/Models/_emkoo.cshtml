@model GAC.Core.Content.Vehicle
@{
    var hero = Model.Images.FirstOrDefault(i => i.Kind == GAC.Core.Content.VehicleImageKind.Hero)?.Path;
}

  <main class="mp">

    <!-- ============ HERO / INTRO BANNER ============ -->
    <section class="mp-hero">
      <a class="mp-hero__link" href="#enquiry" aria-label="Book a Test Drive">
        <img class="mp-hero__img" src="@hero" alt="2026 GAC EMKOO" />
        <div class="mp-hero__overlay">
          <div class="container">
            <h1 class="mp-hero__title">@Model.Name.Localize()</h1>
            <p class="mp-hero__sub">The All-New Crossover SUV</p>
            <span class="btn btn--hero">Book a Test Drive</span>
          </div>
        </div>
      </a>
    </section>

    <!-- ============ SECTION JUMP NAV ============ -->
    <nav class="mp-subnav" aria-label="Model sections">
      <div class="container mp-subnav__inner">
        <a class="btn btn--subnav" href="#trims">Price and Trims</a>
        <div class="mp-subnav__links">
          <a href="#exterior" class="is-active">Exterior</a>
          <a href="#design">Design</a>
          <a href="#interior">Interior</a>
          <a href="#gallery">Gallery</a>
          <a href="#quality">Quality</a>
          <a href="#technology">Technology</a>
          <a href="#performance">Performance</a>
          <a href="#safety">Safety</a>
          <a href="#warranty">Warranty</a>
        </div>
        <a class="btn btn--subnav" href="#enquiry">Order Online</a>
      </div>
    </nav>

    <!-- ============ OVERVIEW ============ -->
    <section class="mp-section" id="exterior">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">GAC EMKOO</h2>
          <p class="mp-head__sub">Unleash The Future</p>
        </header>
        <div class="mp-stats">
          <div class="mp-stat"><span class="mp-stat__label">Fuel Consumption</span><span class="mp-stat__value">18.2 KM/L</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Horsepower</span><span class="mp-stat__value">177 HP</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Engine</span><span class="mp-stat__value">1.5L Turbo</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Seating</span><span class="mp-stat__value">5</span></div>
        </div>
        <p class="mp-note">*Fuel consumption differs from a trim to another. You can refer to specifications of all trims below for more information.</p>
      </div>
    </section>

    <!-- ============ EXTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/emkoo/ext-1.jpg" alt="EMKOO exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/emkoo/ext-2.jpg" alt="EMKOO exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/emkoo/ext-3.jpg" alt="EMKOO exterior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Exterior</span>
          <span class="mp-slider__title">Powerful Design</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ DESIGN ============ -->
    <section class="mp-section" id="design">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Design</h2>
          <p class="mp-head__sub">Experience-centric design</p>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="d1">Exterior Details Make the Difference</button>
            <button class="mp-tabs__btn" data-tab-btn="d2">Interior Design with Safety and Comfort First</button>
            <button class="mp-tabs__btn" data-tab-btn="d3">An Immersive Experience About Technology</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-feature is-active" data-tab-panel="d1">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/design-1.jpg" alt="EMKOO exterior details" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Exterior Details Make the Difference</h3>
                <p>A front end with a modern and bold design inspired by the future.</p>
                <ul class="mp-feature__list">
                  <li><strong>LED Headlights:</strong> High-tech LED headlights provide a clear view of the road and a bold, modern look.</li>
                  <li><strong>19-inch Alloy Wheels:</strong> Hard to ignore, and ensure a comfortable ride on all terrains.</li>
                  <li><strong>Panoramic Glass Roof:</strong> Glass ceiling with electric sun visor gives you natural lighting and lets you enjoy all the weather.</li>
                  <li><strong>Welcome Lights:</strong> Stylish front and rear lights with welcome function make EMKOO a reflection of your personality.</li>
                  <li><strong>Rain-sensing Wipers &amp; Electric Tailgate:</strong> Automatic wipers adapt to changing conditions, and the electric tailgate frees your hands.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d2">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/design-2.jpg" alt="EMKOO interior comfort" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Interior Design with Safety and Comfort First</h3>
                <p>Elegant interior design with a wide selection of colours, luxurious materials, and elegant touches.</p>
                <ul class="mp-feature__list">
                  <li><strong>Automatic Air Conditioning:</strong> Including second-row passengers, with an air-quality sensor.</li>
                  <li><strong>Electrically Adjustable Seats:</strong> Driver and passenger seats adjust with electrical control.</li>
                  <li><strong>Ventilated Seats:</strong> Cool off on long trips with ventilated first-row seats.</li>
                  <li><strong>Intelligent Multi-colour Ambient Lighting:</strong> Customise colour and brightness to suit your mood.</li>
                  <li><strong>Forward Collision Warning &amp; Self-emergency Braking:</strong> Advanced sensors keep you safe and aware on the road.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d3">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/design-3.jpg" alt="EMKOO technology experience" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">An Immersive Experience About Technology</h3>
                <ul class="mp-feature__list">
                  <li><strong>7-inch LCD Instrument Panel:</strong> A clear, customizable view of key driving data.</li>
                  <li><strong>10.1-inch Touchscreen:</strong> An immersive, engaging interface with easy access to entertainment, navigation and settings.</li>
                  <li><strong>6 Speakers:</strong> Clear, immersive sound with speed-adaptive volume.</li>
                  <li><strong>Smartphone Connectivity:</strong> Seamless Apple CarPlay + Android integration.</li>
                  <li><strong>USB Type-A and Type-C Ports:</strong> Keep you and your companions connected on the go.</li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap" id="interior">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/emkoo/int-1.jpg" alt="EMKOO interior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/emkoo/int-2.jpg" alt="EMKOO interior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Interior</span>
          <span class="mp-slider__title">Feel relaxed, feel free.</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ GALLERY ============ -->
    <section class="mp-section" id="gallery">
      <div class="container">
        <header class="mp-head mp-head--center">
          <h2 class="mp-head__title">Gallery</h2>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="gex">Exterior</button>
            <button class="mp-tabs__btn" data-tab-btn="gin">Interior</button>
            <button class="mp-tabs__btn" data-tab-btn="gte">Technology</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-gpanel is-active" data-tab-panel="gex">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-1.jpg"><img src="/assets/img/emkoo/gal-1.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-2.jpg"><img src="/assets/img/emkoo/gal-2.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-3.jpg"><img src="/assets/img/emkoo/gal-3.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-4.jpg"><img src="/assets/img/emkoo/gal-4.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-5.jpg"><img src="/assets/img/emkoo/gal-5.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-6.jpg"><img src="/assets/img/emkoo/gal-6.jpg" alt="EMKOO exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gin">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-1.jpg"><img src="/assets/img/emkoo/gal-int-1.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-2.jpg"><img src="/assets/img/emkoo/gal-int-2.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-3.jpg"><img src="/assets/img/emkoo/gal-int-3.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-4.jpg"><img src="/assets/img/emkoo/gal-int-4.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-5.jpg"><img src="/assets/img/emkoo/gal-int-5.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-int-6.jpg"><img src="/assets/img/emkoo/gal-int-6.jpg" alt="EMKOO interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gte">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-tech-1.jpg"><img src="/assets/img/emkoo/gal-tech-1.jpg" alt="EMKOO technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-tech-2.jpg"><img src="/assets/img/emkoo/gal-tech-2.jpg" alt="EMKOO technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/emkoo/gal-tech-3.jpg"><img src="/assets/img/emkoo/gal-tech-3.jpg" alt="EMKOO technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ QUALITY ============ -->
    <section class="mp-section" id="quality">
      <div class="container">
        <div class="mp-quality">
          <div class="mp-quality__main">
            <img src="/assets/img/emkoo/jdpower-award.jpg" alt="J.D. Power award — GAC EMKOO" />
          </div>
          <aside class="mp-quality__card">
            <div class="mp-quality__thumb"><img src="/assets/img/emkoo/quality-thumb.jpg" alt="EMKOO" loading="lazy" /></div>
            <div class="mp-quality__text">
              <span class="mp-quality__strapline">Extraordinary Standards</span>
              <p class="mp-quality__content">Winner of the J.D. Power prize for 8 Years in a row.</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ TECHNOLOGY ============ -->
    <section class="mp-section mp-section--grey" id="technology">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Smart Technologies</h2>
          <p class="mp-head__sub">The ultimate driving experience with innovative technology</p>
        </header>
        <div class="mp-tech-banner"><img src="/assets/img/emkoo/tech-banner.jpg" alt="EMKOO smart technologies" /></div>
        <div class="mp-cards">
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/emkoo/tech-1.jpg" alt="10.1-inch Smart Infotainment System" /></div>
            <h3 class="mp-card__title">10.1-inch Smart Infotainment System</h3>
            <p class="mp-card__text">10.1-inch touch hi-tech infotainment system with navigation and entertainment functionality.</p>
          </article>
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/emkoo/tech-2.jpg" alt="Crystal shift gear knob" /></div>
            <h3 class="mp-card__title">Crystal Shift Gear Knob</h3>
            <p class="mp-card__text">A regal crystal shift gear knob that adds elegance.</p>
          </article>
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/emkoo/tech-3.jpg" alt="Exhilarating digital dashboard" /></div>
            <h3 class="mp-card__title">Exhilarating Digital Dashboard</h3>
            <p class="mp-card__text">Ultra-modern digital dashboard for a thrilling driving experience.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ PERFORMANCE ============ -->
    <section class="mp-section" id="performance">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Performance</h2>
          <p class="mp-head__sub">Seamless Control, Dynamic Force</p>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="p1">Unleash the Power</button>
            <button class="mp-tabs__btn" data-tab-btn="p2">Reinforced Leadership, More Than a Slogan</button>
            <button class="mp-tabs__btn" data-tab-btn="p3">Safety at the Heart of Design</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-feature is-active" data-tab-panel="p1">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/perf-1.jpg" alt="EMKOO 1.5T engine" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Unleash the Power</h3>
                <p>Experience the high-performance EMKOO engine.</p>
                <ul class="mp-feature__list">
                  <li><strong>1.5L TGDI Engine:</strong> 177 hp with a seven-speed dual-clutch automatic transmission — perfect performance and a smooth experience.</li>
                  <li><strong>Electronic Parking Brake (EPB) with Autohold.</strong></li>
                  <li><strong>Suspension Built for Comfort:</strong> Front McPherson independent; rear multi-link beam independent.</li>
                  <li><strong>Airbags:</strong> Dual front, front side and side-curtain airbags.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="p2">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/perf-2.jpg" alt="EMKOO smart driving systems" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Reinforced Leadership, More Than a Slogan</h3>
                <p>EMKOO is equipped with smart systems that relieve driving stress and enhance safety and security.</p>
                <ul class="mp-feature__list">
                  <li><strong>Adaptive Cruise Control:</strong> Automatically maintains a safe distance from the vehicle ahead.</li>
                  <li><strong>AEB &amp; AEB-VRU:</strong> Autonomous emergency braking with protection for vulnerable road users.</li>
                  <li><strong>Lane Keeping Assist (LKA) &amp; Lane Departure Warning (LDW):</strong> Enhanced attention while driving.</li>
                  <li><strong>TSR &amp; Traffic Jam Assist (TJA):</strong> Your intelligent assistant to reach your destination safely.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="p3">
              <div class="mp-feature__media"><img src="/assets/img/emkoo/perf-3.jpg" alt="EMKOO safety design" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Safety at the Heart of Design</h3>
                <p>EMKOO includes all the necessary details to ensure the safety of the driver and passengers, so the driving experience remains pure pleasure.</p>
                <ul class="mp-feature__list">
                  <li><strong>Hill Start Control (HHC) &amp; Hill Descent Control (HDC):</strong> Make driving on a slope as comfortable as a flat road.</li>
                  <li><strong>Door Opening Warning (DOW):</strong> Helps avoid accidents when getting out of the car.</li>
                  <li><strong>Electronic Child Safety Lock:</strong> So you never forget the safety of the most important person in the car.</li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ SAFETY ============ -->
    <section class="mp-section mp-section--grey" id="safety">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Safety</h2>
          <p class="mp-head__sub">Safety First: Our Obsessive Care Gives You Peace of Mind</p>
          <p class="mp-head__body">You are provided with active and passive safety systems for meticulous and all-round protection. More airbags are provided for an all-round protection. It also has several safety features such as Automotive Emergency Braking (AEB), Forward Collision Warning (FWC), Lane Departure Warning (LDW) and High-Beam Assist (HMA). *Safety specifications differ depending on trim. You can refer to specifications of all trims below for more information.</p>
        </header>
        <div class="mp-stoggles">
          <article class="mp-stoggle is-open">
            <button class="mp-stoggle__head" type="button" aria-expanded="true"><span>Autonomous Emergency Braking</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/emkoo/safe-1.jpg" alt="Autonomous Emergency Braking Technology" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">Autonomous Emergency Braking Technology</h3>
              <p class="mp-stoggle__content">Safety features that are prepared for the unexpected.</p>
            </div>
          </article>
          <article class="mp-stoggle">
            <button class="mp-stoggle__head" type="button" aria-expanded="false"><span>6 SRS Airbags</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/emkoo/safe-2.jpg" alt="6 SRS Airbags" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">6 SRS Airbags</h3>
              <p class="mp-stoggle__content">Dual front SRS airbags and integrated side-curtain airbags to ensure passenger safety.</p>
            </div>
          </article>
          <article class="mp-stoggle">
            <button class="mp-stoggle__head" type="button" aria-expanded="false"><span>Safety is a Top Priority</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/emkoo/safe-3.jpg" alt="ISOFix child safety seat anchors" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">Safety is a Top Priority</h3>
              <p class="mp-stoggle__content">ISOFix child safety seat anchors.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ TRIMS ============ -->
    <section class="mp-section" id="trims">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">GAC EMKOO</h2>
          <p class="mp-head__sub">Choose the right trim level for you</p>
          <p class="mp-head__body">The price does not include registration fees and plates<br>Terms and conditions apply</p>
