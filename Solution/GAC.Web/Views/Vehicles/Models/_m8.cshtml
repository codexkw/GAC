@model GAC.Core.Content.Vehicle
@{
    var hero = Model.Images.FirstOrDefault(i => i.Kind == GAC.Core.Content.VehicleImageKind.Hero)?.Path;
}

  <main class="mp">

    <!-- ============ HERO / INTRO BANNER ============ -->
    <section class="mp-hero">
      <a class="mp-hero__link" href="#enquiry" aria-label="Book a Test Drive">
        <img class="mp-hero__img" src="@hero" alt="2026 GAC M8" />
        <div class="mp-hero__overlay">
          <div class="container">
            <h1 class="mp-hero__title">@Model.Name.Localize()</h1>
            <p class="mp-hero__sub">It Opens New Horizons, Leading Its Generation</p>
            <span class="btn btn--hero">Book a Test Drive</span>
          </div>
        </div>
      </a>
    </section>

    <!-- ============ SECTION JUMP NAV ============ -->
    <nav class="mp-subnav" aria-label="Model sections">
      <div class="container mp-subnav__inner">
        <a class="btn btn--subnav" href="#trims">Price and Trims</a>
        <div class="mp-subnav__links">
          <a href="#exterior" class="is-active">Exterior</a>
          <a href="#design">Design</a>
          <a href="#interior">Interior</a>
          <a href="#gallery">Gallery</a>
          <a href="#quality">Quality</a>
          <a href="#technology">Technology</a>
          <a href="#performance">Performance</a>
          <a href="#safety">Safety</a>
          <a href="#warranty">Warranty</a>
        </div>
        <a class="btn btn--subnav" href="#enquiry">Order Online</a>
      </div>
    </nav>

    <!-- ============ OVERVIEW ============ -->
    <section class="mp-section" id="exterior">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">GAC M8</h2>
          <p class="mp-head__sub">Inspiring Lion-like Presence</p>
        </header>
        <div class="mp-stats">
          <div class="mp-stat"><span class="mp-stat__label">Fuel Consumption</span><span class="mp-stat__value">13.1 KM/L</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Horsepower</span><span class="mp-stat__value">252 HP</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Engine</span><span class="mp-stat__value">2.0L Turbo</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Seating</span><span class="mp-stat__value">7</span></div>
        </div>
        <p class="mp-note">*Fuel consumption differs from a trim to another. You can refer to specifications of all trims below for more information.</p>
      </div>
    </section>

    <!-- ============ EXTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/m8/ext-1.jpg" alt="M8 exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/m8/ext-2.jpg" alt="M8 exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/m8/ext-3.jpg" alt="M8 exterior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Exterior</span>
          <span class="mp-slider__title">Powerful Design</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ DESIGN ============ -->
    <section class="mp-section" id="design">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Design</h2>
          <p class="mp-head__sub">Robust and Luxurious Design</p>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="d1">Strong and Vibrant Front Face</button>
            <button class="mp-tabs__btn" data-tab-btn="d2">Details Filled with Luxury</button>
            <button class="mp-tabs__btn" data-tab-btn="d3">Luxurious Interior Cabin</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-feature is-active" data-tab-panel="d1">
              <div class="mp-feature__media"><img src="/assets/img/m8/design-1.jpg" alt="M8 strong front face" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Strong Front Design Full of Vitality</h3>
                <p>A single glance is enough to admire a strong frontal face full of vitality.</p>
                <ul class="mp-feature__list">
                  <li><strong>Inspiring Wing Grille:</strong> A chrome grille with 10 bars, its design reminiscent of the lion's heavy mane, giving the front facade a majestic appearance.</li>
                  <li><strong>"Lion Eyes" Front Lights:</strong> Eye-catching front lights equipped with 388 LED bulbs, resembling shining lion eyes when turned on.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d2">
              <div class="mp-feature__media"><img src="/assets/img/m8/design-2.jpg" alt="M8 rear lights and wheels" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Rear Lights &amp; Floating-Star Wheels</h3>
                <p>Luxury and futuristic detail at every angle.</p>
                <ul class="mp-feature__list">
                  <li><strong>Connected Rear Lights:</strong> 320 LED bulbs that, when lit, feel like opening the gate of time — the turn signal adds a wonderful, futuristic light display.</li>
                  <li><strong>Floating-Star Edge Wheels:</strong> 18-inch rims with a three-dimensional logo and varied-thickness bars for a luxurious, elegant style.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d3">
              <div class="mp-feature__media"><img src="/assets/img/m8/design-3.jpg" alt="M8 luxurious interior cabin" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">The Luxurious Interior Cabin</h3>
                <p>A comfortable, enjoyable and noise-free driving experience.</p>
                <ul class="mp-feature__list">
                  <li><strong>Electric Side Doors:</strong> Effortless, elegant access for every passenger.</li>
                  <li><strong>Elegant Interior Lighting:</strong> Harmonious ambient lights and soft reading lights create a luxurious, comfortable mood.</li>
                  <li><strong>Exclusive Luxurious Space:</strong> A distinctive driving and riding experience in a comfortable, noise-free environment.</li>
                  <li><strong>Flexible Cabin Space:</strong> Adjustable, folding third-row seats and adjustable second-row seats transform the cabin for work and family trips.</li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap" id="interior">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/m8/int-1.jpg" alt="M8 interior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/m8/int-2.jpg" alt="M8 interior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Interior</span>
          <span class="mp-slider__title">Feel relaxed, feel free.</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ GALLERY ============ -->
    <section class="mp-section" id="gallery">
      <div class="container">
        <header class="mp-head mp-head--center">
          <h2 class="mp-head__title">Gallery</h2>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="gex">Exterior</button>
            <button class="mp-tabs__btn" data-tab-btn="gin">Interior</button>
            <button class="mp-tabs__btn" data-tab-btn="gte">Technology</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-gpanel is-active" data-tab-panel="gex">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/m8/gal-1.jpg"><img src="/assets/img/m8/gal-1.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-2.jpg"><img src="/assets/img/m8/gal-2.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-3.jpg"><img src="/assets/img/m8/gal-3.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-4.jpg"><img src="/assets/img/m8/gal-4.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-5.jpg"><img src="/assets/img/m8/gal-5.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-6.jpg"><img src="/assets/img/m8/gal-6.jpg" alt="M8 exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gin">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-1.jpg"><img src="/assets/img/m8/gal-int-1.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-2.jpg"><img src="/assets/img/m8/gal-int-2.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-3.jpg"><img src="/assets/img/m8/gal-int-3.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-4.jpg"><img src="/assets/img/m8/gal-int-4.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-5.jpg"><img src="/assets/img/m8/gal-int-5.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-int-6.jpg"><img src="/assets/img/m8/gal-int-6.jpg" alt="M8 interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gte">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/m8/gal-tech-1.jpg"><img src="/assets/img/m8/gal-tech-1.jpg" alt="M8 technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-tech-2.jpg"><img src="/assets/img/m8/gal-tech-2.jpg" alt="M8 technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/m8/gal-tech-3.jpg"><img src="/assets/img/m8/gal-tech-3.jpg" alt="M8 technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ QUALITY ============ -->
    <section class="mp-section" id="quality">
      <div class="container">
        <div class="mp-quality">
          <div class="mp-quality__main">
            <img src="/assets/img/m8/jdpower-award.jpg" alt="J.D. Power award — GAC M8" />
          </div>
          <aside class="mp-quality__card">
            <div class="mp-quality__thumb"><img src="/assets/img/m8/quality-thumb.jpg" alt="M8" loading="lazy" /></div>
            <div class="mp-quality__text">
              <span class="mp-quality__strapline">Extraordinary Standards</span>
              <p class="mp-quality__content">Winner of the J.D. Power prize for 8 Years in a row.</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ TECHNOLOGY ============ -->
    <section class="mp-section mp-section--grey" id="technology">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Smart Technologies</h2>
          <p class="mp-head__sub">The M8 is equipped with multiple technologies such as wireless charging, electronic parking brakes with automatic hold, and a tire pressure monitoring system.</p>
        </header>
        <div class="mp-tech-banner"><img src="/assets/img/m8/tech-banner.jpg" alt="M8 smart technologies" /></div>
        <div class="mp-cards">
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/m8/tech-1.jpg" alt="14.6-inch touchscreen entertainment display" /></div>
            <h3 class="mp-card__title">Multi-function 14.6-inch Touchscreen Entertainment Display</h3>
            <p class="mp-card__text">Apple CarPlay and Android Auto.</p>
          </article>
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/m8/tech-2.jpg" alt="High-tech captain seats" /></div>
            <h3 class="mp-card__title">High-Tech Seats</h3>
            <p class="mp-card__text">The captain's seats in the second row are electrically adjustable with heating, ventilation, and electrically adjustable leg rests.</p>
          </article>
          <article class="mp-card">
            <div class="mp-card__media"><img src="/assets/img/m8/tech-3.jpg" alt="Advanced driver assistance system" /></div>
            <h3 class="mp-card__title">Advanced Driver Assistance System</h3>
            <p class="mp-card__text">360-degree Surround View Camera.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ PERFORMANCE ============ -->
    <section class="mp-section" id="performance">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Performance</h2>
          <p class="mp-head__sub">Powerful Performance</p>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="p1">Second-generation Engine From GAC Motor</button>
            <button class="mp-tabs__btn" data-tab-btn="p2">Dynamic and Quality Mastered</button>
            <button class="mp-tabs__btn" data-tab-btn="p3">Advanced Driver Assistance Systems</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-feature is-active" data-tab-panel="p1">
              <div class="mp-feature__media"><img src="/assets/img/m8/perf-1.jpg" alt="M8 2.0T turbo engine" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Second-generation Engine From GAC Motor</h3>
                <p>Powerful 2-litre turbo engine with a direct fuel-injection system, paired with an AT8 torque-converter automatic.</p>
                <ul class="mp-feature__list">
                  <li><strong>Fourth-generation 2.0T Engine:</strong> Direct fuel injection from GAC, featuring 10 core technologies.</li>
                  <li><strong>252 HP &amp; up to 400 Nm:</strong> Maximum torque of up to 400 Nm for confident, powerful acceleration.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="p2">
              <div class="mp-feature__media"><img src="/assets/img/m8/perf-2.jpg" alt="M8 intelligent suspension" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Dynamic and Quality Mastered</h3>
                <p>The intelligent electromagnetic suspension adjusts the damping force of all four shock absorbers in real time based on road conditions, vehicle state and driver intent.</p>
                <ul class="mp-feature__list">
                  <li><strong>Traffic Sign Recognition (TSR).</strong></li>
                  <li><strong>Rear Car Approaching Warning (RAW).</strong></li>
                  <li><strong>Intelligent Speed-Limit Adaptive Cruise Control (ISL-ACC).</strong></li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="p3">
              <div class="mp-feature__media"><img src="/assets/img/m8/perf-3.jpg" alt="M8 advanced driver assistance" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Advanced Driver Assistance Systems</h3>
                <ul class="mp-feature__list">
                  <li><strong>Traffic Jam Assist (TJA).</strong></li>
                  <li><strong>Integrated Cruise Assist (ICA).</strong></li>
                  <li><strong>Forward Collision Warning (FCW).</strong></li>
                  <li><strong>Lane Departure Warning (LDW).</strong></li>
                  <li><strong>Fusion Automatic Parking Assist (FAPA).</strong></li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ SAFETY ============ -->
    <section class="mp-section mp-section--grey" id="safety">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Safety Technology, Ensures You Higher Safety Standards</h2>
          <p class="mp-head__sub">Have a smart, safe trip</p>
          <p class="mp-head__body">Equipped with several features, including a direct tire pressure monitoring system, a rear camera, an automatic emergency braking system (AEB), a lane departure warning system (LDW), a 360-degree panoramic imaging system, and a high-strength steel safety structure to provide you and your family with maximum protection. To learn about the available safety features in all categories, please refer to the specifications for each category below.</p>
        </header>
        <div class="mp-stoggles">
          <article class="mp-stoggle is-open">
            <button class="mp-stoggle__head" type="button" aria-expanded="true"><span>Integrated 360-Degree Airbags</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/m8/safe-1.jpg" alt="Integrated 360-degree airbags" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">Integrated 360-Degree Airbags</h3>
              <p class="mp-stoggle__content">Patented rear-window airbags + curtain airbags (a single-piece airbag measuring 3.2 metres that covers three rows) + standard airbags. This set of integrated airbags is the first of its kind, designed to ensure your safety.</p>
            </div>
          </article>
          <article class="mp-stoggle">
            <button class="mp-stoggle__head" type="button" aria-expanded="false"><span>Level 2 Autonomous Driving</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/m8/safe-2.jpg" alt="Level 2 autonomous driving assistant system" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">Level 2 Autonomous Driving Assistant System</h3>
              <p class="mp-stoggle__content">Also equipped with Lane Keeping Assist (LKA), Adaptive Cruise Control (ACC), Autonomous Emergency Braking (AEB), and Blind Spot Monitoring.</p>
            </div>
          </article>
          <article class="mp-stoggle">
            <button class="mp-stoggle__head" type="button" aria-expanded="false"><span>Intelligent Driving Ecosystem</span><i class="mp-stoggle__icon"></i></button>
            <div class="mp-stoggle__body">
              <div class="mp-stoggle__media"><img src="/assets/img/m8/safe-3.jpg" alt="Intelligent driving ecosystem ADiGO" loading="lazy" /></div>
              <h3 class="mp-stoggle__strap">Intelligent Driving Ecosystem (ADiGO)</h3>
              <p class="mp-stoggle__content">Integrating entertainment, navigation and Over-The-Air (OTA) synchronization to create a personalized cockpit at the driver level.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ TRIMS ============ -->
    <section class="mp-section" id="trims">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">GAC M8</h2>
          <p class="mp-head__sub">Choose the right trim level for you</p>
          <p class="mp-head__body">The price does not include registration fees and plates<br>Terms and conditions apply</p>
        </header>
        <div class="mp-trims" style="gap:var(--space-7); flex-wrap:wrap;">
          <article class="mp-trim">
            <div class="mp-trim__media"><img src="/assets/img/m8/trim-m8.png" alt="M8 GT" /></div>
            <div class="mp-trim__body">
              <p class="mp-trim__model">M8</p>
              <h3 class="mp-trim__name">GT</h3>
              <ul class="mp-trim__price">
                <li>Price: KWD 141,250</li>
                <li>VAT: KWD 21,187.50</li>
                <li>Total including VAT: KWD 162,437.50</li>
              </ul>
              <div class="mp-trim__cta">
                <a class="btn btn--trim" href="#enquiry">Book A test drive</a>
                <a class="btn btn--trim" href="/pdfs/m8-specifications.pdf" target="_blank" rel="noopener">Specifications</a>
              </div>
            </div>
          </article>
          <article class="mp-trim">
