@model GAC.Core.Content.Vehicle
@{
    var hero = Model.Images.FirstOrDefault(i => i.Kind == GAC.Core.Content.VehicleImageKind.Hero)?.Path;
}

  <main class="mp">

    <!-- ============ HERO / INTRO BANNER ============ -->
    <section class="mp-hero">
      <a class="mp-hero__link" href="#enquiry" aria-label="Book a Test Drive">
        <img class="mp-hero__img" src="@hero" alt="2026 GAC EMPOW R" />
        <div class="mp-hero__overlay">
          <div class="container">
            <h1 class="mp-hero__title">@Model.Name.Localize()</h1>
            <p class="mp-hero__sub">Limitless Acceleration</p>
            <span class="btn btn--hero">Book a Test Drive</span>
          </div>
        </div>
      </a>
    </section>

    <!-- ============ SECTION JUMP NAV ============ -->
    <nav class="mp-subnav" aria-label="Model sections">
      <div class="container mp-subnav__inner">
        <a class="btn btn--subnav" href="#trims">Price and Trims</a>
        <div class="mp-subnav__links">
          <a href="#exterior" class="is-active">Exterior</a>
          <a href="#design">Design</a>
          <a href="#interior">Interior</a>
          <a href="#gallery">Gallery</a>
          <a href="#quality">Quality</a>
          <a href="#technology">Technology</a>
          <a href="#performance">Performance</a>
          <a href="#safety">Safety</a>
          <a href="#warranty">Warranty</a>
        </div>
        <a class="btn btn--subnav" href="#enquiry">Order Online</a>
      </div>
    </nav>

    <!-- ============ OVERVIEW ============ -->
    <section class="mp-section" id="exterior">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">EMPOW R</h2>
          <p class="mp-head__sub">The Bullet</p>
        </header>
        <div class="mp-stats">
          <div class="mp-stat"><span class="mp-stat__label">Fuel Consumption</span><span class="mp-stat__value">18.1 KM/L</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Horsepower</span><span class="mp-stat__value">265 HP</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Engine</span><span class="mp-stat__value">2.0L GDI Turbo</span></div>
          <div class="mp-stat"><span class="mp-stat__label">Seating</span><span class="mp-stat__value">5</span></div>
        </div>
        <p class="mp-note">*Fuel consumption differs from a trim to another. You can refer to specifications of all trims below for more information.</p>
      </div>
    </section>

    <!-- ============ EXTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/empow-sport/ext-1.jpg" alt="EMPOW R exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/empow-sport/ext-2.jpg" alt="EMPOW R exterior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/empow-sport/ext-3.jpg" alt="EMPOW R exterior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Exterior</span>
          <span class="mp-slider__title">Powerful Design</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ DESIGN ============ -->
    <section class="mp-section" id="design">
      <div class="container">
        <header class="mp-head mp-head--left">
          <h2 class="mp-head__title">Design</h2>
          <p class="mp-head__sub">Impressive fighter design</p>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="d1">Elegant and Dynamic Design</button>
            <button class="mp-tabs__btn" data-tab-btn="d2">Limitless Acceleration</button>
            <button class="mp-tabs__btn" data-tab-btn="d3">Innovative Aesthetics</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-feature is-active" data-tab-panel="d1">
              <div class="mp-feature__media"><img src="/assets/img/empow-sport/design-1.jpg" alt="EMPOW R elegant and dynamic design" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Elegant and Dynamic Design</h3>
                <ul class="mp-feature__list">
                  <li><strong>Sporty and Striking Look:</strong> Features a sporty rear spoiler, dual exhaust outlets, and an electric sunroof for a bold and performance-inspired appearance.</li>
                  <li><strong>High-Tech LED Headlamps:</strong> Equipped with advanced LED headlights, the EMPOW delivers superior visibility and a modern, assertive presence on the road.</li>
                  <li><strong>18" Aluminum Wheels with Michelin Tires:</strong> A perfect blend of modern style, lightweight durability, and high-performance grip for an unmatched driving experience.</li>
                  <li><strong>Sleek LED Taillights:</strong> Eye-catching and contemporary taillights leave a bold impression while ensuring excellent rear visibility for a safer, more enjoyable drive.</li>
                  <li><strong>Power Adjustable &amp; Folding Side Mirrors:</strong> Enhancing comfort and visibility, these mirrors are seamlessly integrated into the vehicle's sleek overall design.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d2">
              <div class="mp-feature__media"><img src="/assets/img/empow-sport/design-2.jpg" alt="EMPOW R limitless acceleration" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Limitless Acceleration</h3>
                <p>0–100 km/h in just 5.7 seconds with 265 HP. Experience the thrill of the high-performance EMPOW 2.0T Sport engine combined with cutting-edge driver assistance systems.</p>
                <ul class="mp-feature__list">
                  <li><strong>Smart Adaptive Cruise Control with Radar (ACC) &amp; Integrated Cruise Assist (ICA):</strong> Automatically adjusts your speed to maintain a safe distance from the vehicle ahead, delivering a smoother, semi-autonomous driving experience.</li>
                  <li><strong>Intelligent Speed Limit Recognition System:</strong> Reads road speed limits and helps ensure driving compliance.</li>
                  <li><strong>Traffic Jam Assist (TJA):</strong> Eases stop-and-go driving by helping maintain safe spacing and lane positioning in congested traffic.</li>
                  <li><strong>Self-Learning Transmission &amp; Neutral Control:</strong> Adapts to your driving style for smoother shifts, and disengages the gear at idle to improve efficiency.</li>
                  <li><strong>Manual Mode &amp; Paddle Shifters:</strong> Simulates manual transmission performance, strengthening the connection between driver and machine.</li>
                  <li><strong>Bosch ESP10.0 &amp; DP-EPS Electric Power Steering:</strong> Confident control in all conditions with direct steering feedback for greater precision.</li>
                </ul>
              </div>
            </div>

            <div class="mp-feature" data-tab-panel="d3">
              <div class="mp-feature__media"><img src="/assets/img/empow-sport/design-3.jpg" alt="EMPOW R innovative aesthetics" /></div>
              <div class="mp-feature__body">
                <h3 class="mp-feature__title">Innovative Aesthetics</h3>
                <p>An interior that strikes the perfect balance between elegance and sportiness, with premium materials and supportive seats.</p>
                <ul class="mp-feature__list">
                  <li><strong>7-inch Instrument Panel:</strong> A colour LCD multi-information display with a clear, customizable view.</li>
                  <li><strong>10.25" Colour LCD Screen:</strong> Stunning graphics and intuitive controls for an immersive experience.</li>
                  <li><strong>6 Sound Speakers:</strong> Crisp, immersive sound that elevates every drive.</li>
                  <li><strong>Smartphone Connection:</strong> CarPlay &amp; FunDrive Link, plus a wireless charger and first &amp; second row USB ports.</li>
                  <li><strong>Adaptive Cruise Control &amp; Autonomous Emergency Braking:</strong> A stress-free drive with an extra layer of safety.</li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTERIOR CAROUSEL ============ -->
    <section class="mp-slider-wrap" id="interior">
      <div class="mp-slider" data-slider>
        <div class="mp-slider__viewport">
          <div class="mp-slider__track" data-slider-track>
            <figure class="mp-slide"><img src="/assets/img/empow-sport/int-1.jpg" alt="EMPOW R interior" /></figure>
            <figure class="mp-slide"><img src="/assets/img/empow-sport/int-2.jpg" alt="EMPOW R interior" /></figure>
          </div>
        </div>
        <div class="mp-slider__caption">
          <span class="mp-slider__eyebrow">Interior</span>
          <span class="mp-slider__title">Feel relaxed, feel free.</span>
        </div>
        <button class="mp-slider__arrow mp-slider__arrow--prev" data-slider-prev aria-label="Previous">‹</button>
        <button class="mp-slider__arrow mp-slider__arrow--next" data-slider-next aria-label="Next">›</button>
      </div>
    </section>

    <!-- ============ GALLERY ============ -->
