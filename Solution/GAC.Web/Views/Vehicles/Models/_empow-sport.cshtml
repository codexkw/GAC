        <header class="mp-head mp-head--center">
          <h2 class="mp-head__title">Gallery</h2>
        </header>

        <div class="mp-tabs" data-tabs-wrap>
          <div class="mp-tabs__nav" data-tabs>
            <button class="mp-tabs__btn is-active" data-tab-btn="gex">Exterior</button>
            <button class="mp-tabs__btn" data-tab-btn="gin">Interior</button>
            <button class="mp-tabs__btn" data-tab-btn="gte">Technology</button>
          </div>
          <div class="mp-tabs__root" data-tab-root>

            <div class="mp-gpanel is-active" data-tab-panel="gex">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-1.jpg"><img src="/assets/img/empow-sport/gal-1.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-2.jpg"><img src="/assets/img/empow-sport/gal-2.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-3.jpg"><img src="/assets/img/empow-sport/gal-3.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-4.jpg"><img src="/assets/img/empow-sport/gal-4.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-5.jpg"><img src="/assets/img/empow-sport/gal-5.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-6.jpg"><img src="/assets/img/empow-sport/gal-6.jpg" alt="EMPOW R exterior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gin">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-1.jpg"><img src="/assets/img/empow-sport/gal-int-1.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-2.jpg"><img src="/assets/img/empow-sport/gal-int-2.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-3.jpg"><img src="/assets/img/empow-sport/gal-int-3.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-4.jpg"><img src="/assets/img/empow-sport/gal-int-4.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-5.jpg"><img src="/assets/img/empow-sport/gal-int-5.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-int-6.jpg"><img src="/assets/img/empow-sport/gal-int-6.jpg" alt="EMPOW R interior" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
              </div>
            </div>

            <div class="mp-gpanel" data-tab-panel="gte">
              <div class="mp-gallery">
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-tech-1.jpg"><img src="/assets/img/empow-sport/gal-tech-1.jpg" alt="EMPOW R technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-tech-2.jpg"><img src="/assets/img/empow-sport/gal-tech-2.jpg" alt="EMPOW R technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
                    <a class="mp-gshot" href="/assets/img/empow-sport/gal-tech-3.jpg"><img src="/assets/img/empow-sport/gal-tech-3.jpg" alt="EMPOW R technology" loading="lazy" /><span class="mp-gshot__zoom" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4M11 8v6M8 11h6"/></svg></span></a>
