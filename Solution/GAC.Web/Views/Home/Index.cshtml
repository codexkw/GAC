@model GAC.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["MetaDescription"] = "Discover the 2026 GAC Motor range in Kuwait — SUVs, sedans and EVs — along with offers, showrooms and aftersales services from Mutawa Alkadi Automotive.";
    var slides = Model.Home?.Slides ?? new List<HeroSlide>();
}

  <!-- =================================================
       HERO SLIDER — featured models (DB-driven)
       ================================================= -->
  <section class="hero" aria-label="Featured models">
    <div class="hero__viewport">

@foreach (var slide in slides)
{
      <article class="hero__slide" data-hero-slide>
        <div class="hero__bg hero__bg--img" style="background-image:url('@slide.ImagePath')"></div>
        <div class="hero__inner"><div class="hero__content">
          <div class="hero__eyebrow">@slide.Subheading.Localize()</div>
@if (!string.IsNullOrWhiteSpace(slide.LogoImagePath))
{
          <img class="hero__logo" src="@slide.LogoImagePath" alt="@slide.Heading.Localize()" />
}
else
{
          <h1 class="hero__title">@slide.Heading.Localize()</h1>
}
@if (slide.CtaLink != null)
{
          <a class="btn btn--primary" href="@UrlHelpers.NormalizeUrl(slide.CtaLink)">@(string.IsNullOrWhiteSpace(slide.CtaText.Localize()) ? L["Find Out More"].Value : slide.CtaText.Localize())</a>
}
        </div></div>
      </article>
}

    </div>

    <!-- right action rail -->
    <div class="hero-rail">
      <a href="tel:1833334" aria-label="Call"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1l-2.2 2.2z"/></svg></a>
      <a href="#" aria-label="Saved"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z"/></svg></a>
      <a href="/contact-us" aria-label="Find us"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"/></svg></a>
    </div>

    <div class="hero__arrows">
      <button class="hero__arrow" data-hero-prev aria-label="Previous">‹</button>
      <button class="hero__arrow" data-hero-next aria-label="Next">›</button>
    </div>

    <div class="hero__dots">
@for (var i = 0; i < slides.Count; i++)
{
      <button class="hero__dot" data-hero-dot aria-label="Slide @(i + 1)"></button>
}
    </div>

    <div class="hero__scroll" aria-hidden="true">⌄</div>
  </section>

  <!-- =================================================
       SEARCH AND SHOP ONLINE
       ================================================= -->
  <section class="searchblock">
    <div class="container">
      <h2>@L["Search and Shop Online"]</h2>
      <form class="searchblock__form" onsubmit="event.preventDefault(); if (this.model.value) window.location.href = this.model.value;">
        <select name="model" aria-label="Model">
          <option value="">@L["Model"]</option>
@foreach (var v in Model.Vehicles)
{
          <option value="/@v.Slug">@v.Name.Localize()</option>
}
        </select>
        <button type="submit">@L["Search"]</button>
      </form>
    </div>
  </section>

  <!-- =================================================
       MODEL STRIP — tabs (ALL / SEDAN / SUV / EV), DB-driven
       ================================================= -->
  <section class="model-strip">
    <div class="container">
      <div class="model-strip__head">
        <div data-tabs>
          <div class="tabs" role="tablist">
            <button class="tabs__btn is-active" data-tab-btn="all">@L["All"]</button>
            <button class="tabs__btn" data-tab-btn="sedan">@L["Sedan"]</button>
            <button class="tabs__btn" data-tab-btn="suv">@L["SUV"]</button>
            <button class="tabs__btn" data-tab-btn="ev">@L["EV"]</button>
          </div>
        </div>
      </div>

      <div data-tab-root>

        <!-- ALL -->
        <div class="tabpanel is-active" data-tab-panel="all">
          <div class="carousel" data-carousel>
            <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">‹</button>
            <div class="carousel__viewport"><div class="carousel__track">
@foreach (var v in Model.Vehicles)
{
              <a class="carousel__slide" href="/@v.Slug"><div class="model-card"><div class="model-card__media"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></div><div class="model-card__name">@v.Name.Localize()</div></div></a>
}
            </div></div>
            <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">›</button>
          </div>
          <div class="carousel__dots" data-carousel-dots>
            <button class="carousel__dot is-active" data-cdot="0"></button>
            <button class="carousel__dot" data-cdot="1"></button>
            <button class="carousel__dot" data-cdot="2"></button>
          </div>
        </div>

        <!-- SEDAN -->
        <div class="tabpanel" data-tab-panel="sedan">
          <div class="carousel" data-carousel>
            <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">‹</button>
            <div class="carousel__viewport"><div class="carousel__track">
@foreach (var v in Model.Vehicles.Where(v => v.Category.HasFlag(VehicleCategory.Sedan)))
{
              <a class="carousel__slide" href="/@v.Slug"><div class="model-card"><div class="model-card__media"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></div><div class="model-card__name">@v.Name.Localize()</div></div></a>
}
            </div></div>
            <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">›</button>
          </div>
        </div>

        <!-- SUV -->
        <div class="tabpanel" data-tab-panel="suv">
          <div class="carousel" data-carousel>
            <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">‹</button>
            <div class="carousel__viewport"><div class="carousel__track">
@foreach (var v in Model.Vehicles.Where(v => v.Category.HasFlag(VehicleCategory.Suv)))
{
              <a class="carousel__slide" href="/@v.Slug"><div class="model-card"><div class="model-card__media"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></div><div class="model-card__name">@v.Name.Localize()</div></div></a>
}
            </div></div>
            <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">›</button>
          </div>
        </div>

        <!-- EV -->
        <div class="tabpanel" data-tab-panel="ev">
          <div class="carousel" data-carousel>
            <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">‹</button>
            <div class="carousel__viewport"><div class="carousel__track">
@foreach (var v in Model.Vehicles.Where(v => v.Category.HasFlag(VehicleCategory.Ev)))
{
              <a class="carousel__slide" href="/@v.Slug"><div class="model-card"><div class="model-card__media"><img src="@UrlHelpers.ThumbPath(v)" alt="@v.Name.Localize()" /></div><div class="model-card__name">@v.Name.Localize()</div></div></a>
}
            </div></div>
            <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">›</button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =================================================
       PROMO STRIP — Latest Offers
       ================================================= -->
@{ var promo = Model.Home?.Promo; }
@if (promo != null)
{
  <section class="promo">
    <div class="promo__image promo__image--photo" style="background-image:url('@promo.ImagePath')"></div>
    <div class="promo__content">
      <div class="promo__eyebrow">@promo.Eyebrow.Localize()</div>
      <h2>@promo.Heading.Localize()</h2>
      <p>@promo.Description.Localize()</p>
      <ul class="promo__campaigns">
@foreach (var c in promo.Campaigns)
{
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>@c.Text.Localize()</li>
}
      </ul>
      <a class="btn btn--outline-light" href="@UrlHelpers.NormalizeUrl(promo.CtaLink)">@promo.CtaText.Localize()</a>
    </div>
  </section>
}

  <!-- =================================================
       JUMP TILES — Locations / Book a Service / Parts & Accessories
       ================================================= -->
@{ var cards = Model.Home?.DualCards ?? new List<DualCard>(); }
@if (cards.Count > 0)
{
  <section class="dual">
    <div class="container">
      <div class="dual__grid">
@foreach (var card in cards)
{
        <div class="dual__card">
          <a class="dual__media dual__media--photo" href="@UrlHelpers.NormalizeUrl(card.Link)" aria-label="@card.Title.Localize()" style="background-image:url('@card.ImagePath')"></a>
          <div class="dual__body">
            <div class="dual__eyebrow">@card.Eyebrow.Localize()</div>
            <h3 class="dual__title">@card.Title.Localize()</h3>
            <p class="dual__text">@card.Description.Localize()</p>
            <a class="btn btn--ghost" href="@UrlHelpers.NormalizeUrl(card.Link)">@card.ButtonText.Localize()</a>
          </div>
        </div>
}
      </div>
    </div>
  </section>
}

  <!-- =================================================
       NEWS & EVENTS — header + square-thumb carousel (DB-driven)
       ================================================= -->
  <section class="news">
    <div class="container">
      <div class="news__head">
        <div>
          <h2>@L["News & events"]</h2>
          <p>@L["Keep up to date with all the latest news and stories from MutawaAlkazi Automotive."]</p>
        </div>
        <a class="btn btn--ghost" href="/news">@L["Read All News"]</a>
      </div>

      <div class="newscar" data-news-carousel>
        <button class="newscar__arrow newscar__arrow--prev" data-news-prev aria-label="Previous">‹</button>
        <div class="newscar__viewport">
          <div class="newscar__track" data-news-track>

@foreach (var n in Model.News)
{
        <a class="news-card" href="/news/@n.Slug">
          <div class="news-card__media news-card__media--photo" style="background-image:url('@n.ImagePath')"></div>
          <div class="news-card__body">
            <div class="news-card__date">@n.PublishedOn.ToString("dd MMM yyyy")</div>
            <h3 class="news-card__title">@n.Title.Localize()</h3>
            <span class="news-card__more">@L["Read More"]</span>
          </div>
        </a>
}

          </div>
        </div>
        <button class="newscar__arrow newscar__arrow--next" data-news-next aria-label="Next">›</button>

        <div class="newscar__pager" data-news-pager>
@for (var i = 0; i < Model.News.Count; i++)
{
          <button class="newscar__dot @(i == 0 ? "is-active" : "")" aria-label="Slide @(i + 1)"></button>
}
        </div>
      </div>
    </div>
  </section>
