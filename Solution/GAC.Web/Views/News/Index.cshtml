@model IReadOnlyList<GAC.Core.Content.NewsArticle>
@{ ViewData["Title"] = "News"; }

<section class="page-hero">
  <div class="container">
    <nav class="crumbs"><a href="/">Home</a><span>/</span>News</nav>
    <h1>News &amp; Events</h1>
    <p style="max-width:60ch;color:rgba(255,255,255,.75)">Keep up to date with all the latest GAC news and stories.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="listing-grid">

      @foreach (var n in Model)
      {
        <a class="listing-card" href="/news/@n.Slug">
          <div class="listing-card__media listing-card__media--photo" style="background-image:url('@n.ImagePath');background-size:cover;background-position:center"><span class="listing-card__cat">News</span></div>
          <div class="listing-card__body"><div class="listing-card__date">@n.PublishedOn.ToString("dd MMM yyyy")</div><h3 class="listing-card__title">@n.Title.Localize()</h3><span class="listing-card__more">@L["Read More"]</span></div>
        </a>
      }

    </div>
  </div>
</section>
