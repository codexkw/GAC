@model IReadOnlyList<GAC.Core.Content.Offer>
@{ ViewData["Title"] = "Offers"; }

<section class="page-hero">
  <div class="container">
    <nav class="crumbs"><a href="/">@L["Home"]</a><span>/</span>@L["Offers"]</nav>
    <h1>@L["Latest Offers"]</h1>
    <p style="max-width:60ch;color:rgba(255,255,255,.75)">@L["Limited-time deals and finance packages across the 2026 GAC range."]</p>
  </div>
</section>

<section class="section">
  <div class="container">
@if (Model.Count == 0)
{
    <p class="muted">@L["There are no current offers. Please check back soon."]</p>
}
else
{
    <div class="offer-grid">
@foreach (var o in Model)
{
    var btn = !string.IsNullOrWhiteSpace(o.ButtonLabel.Localize()) ? o.ButtonLabel.Localize() : L["Enquire Now"].Value;
      <div class="offer-card">
        <h3 class="offer-card__title">@o.Title.Localize()</h3>
        <p class="offer-card__text">@o.Body.Localize()</p>
        <a class="btn btn--accent" href="/request-a-quote">@btn</a>
      </div>
}
    </div>
}
  </div>
</section>

<section class="cta-strip">
  <div class="container">
    <h2>@L["Found an offer you like?"]</h2>
    <p>@L["Speak to our team to confirm availability and terms at your nearest showroom."]</p>
    <a class="btn" href="/contact-us">@L["Contact Sales"]</a>
  </div>
</section>
