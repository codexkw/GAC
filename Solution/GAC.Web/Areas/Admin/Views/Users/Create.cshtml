@using Microsoft.AspNetCore.Mvc.Rendering
@model GAC.Web.Areas.Admin.Models.CreateUserViewModel
@{
    ViewData["Title"] = "New user";
}
<p><a asp-action="Index">&larr; Back to users</a></p>

<h1>New user</h1>

<form method="post" asp-action="Create">
    <div asp-validation-summary="All" class="adm-error"></div>

    <div class="adm-field">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" />
    </div>

    <div class="adm-field">
        <label asp-for="DisplayName">Display name</label>
        <input asp-for="DisplayName" />
    </div>

    <div class="adm-field">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" type="password" />
    </div>

    <div class="adm-field">
        <label asp-for="Role">Role</label>
        <select asp-for="Role" asp-items="@((List<SelectListItem>)ViewBag.Roles)"></select>
    </div>

    <button type="submit" class="adm-btn">Create</button>
</form>
