@model GAC.Core.Content.FormPage
@using GAC.Web.Areas.Admin.Models
@{
    ViewData["Title"] = "Edit page";
}
<p><a asp-area="Admin" asp-action="Index">&larr; Back to form pages</a></p>

<h1>Edit page</h1>

<form method="post" asp-action="Save">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Slug" />
    <input type="hidden" asp-for="FormType" />

    <div class="adm-field">
        <label>Slug</label>
        <div>@Model.Slug</div>
    </div>

    <div class="adm-field">
        <label>Form type</label>
        <div>@Model.FormType</div>
    </div>

    <div class="adm-field">
        <label><input asp-for="IsVisible" /> Visible</label>
    </div>

    <div class="adm-field">
        <label asp-for="BannerImagePath">Banner image</label>
        <div class="adm-media">
            @if (string.IsNullOrWhiteSpace(Model.BannerImagePath))
            {
                <img data-media-preview alt="" class="adm-media__preview is-empty" />
            }
            else
            {
                <img data-media-preview alt="" class="adm-media__preview" src="@Model.BannerImagePath" />
            }
            <div class="adm-media__controls">
                <input asp-for="BannerImagePath" data-media-input />
                <button type="button" class="adm-btn" data-media-pick>Choose&hellip;</button>
            </div>
        </div>
    </div>

    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Title", NameEn = "Title.En", NameAr = "Title.Ar", ValueEn = Model.Title.En, ValueAr = Model.Title.Ar }' />
    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Intro text", NameEn = "IntroText.En", NameAr = "IntroText.Ar", ValueEn = Model.IntroText.En, ValueAr = Model.IntroText.Ar, Multiline = true }' />
    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Meta title", NameEn = "MetaTitle.En", NameAr = "MetaTitle.Ar", ValueEn = Model.MetaTitle.En, ValueAr = Model.MetaTitle.Ar }' />
    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Meta description", NameEn = "MetaDescription.En", NameAr = "MetaDescription.Ar", ValueEn = Model.MetaDescription.En, ValueAr = Model.MetaDescription.Ar, Multiline = true }' />

    @if (Model.FormType == GAC.Core.Content.FormType.Contact)
    {
        <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Page body (HTML)", NameEn = "BodyHtml.En", NameAr = "BodyHtml.Ar", ValueEn = Model.BodyHtml.En, ValueAr = Model.BodyHtml.Ar, Code = true }' />
    }
    else
    {
        <p class="adm-note">This page renders a functional lead form; only its title, intro and meta are editable.</p>
    }

    <button type="submit" class="adm-btn">Save</button>
</form>

<partial name="_PickerModal" />

@section Scripts {
<script>
(function () {
  "use strict";
  Array.prototype.forEach.call(document.querySelectorAll("[data-media-input]"), function (input) {
    function sync() {
      var media = input.closest(".adm-media");
      var prev = media ? media.querySelector("[data-media-preview]") : null;
      if (!prev) return;
      var v = (input.value || "").trim();
      if (v) { prev.setAttribute("src", v); prev.classList.remove("is-empty"); }
      else { prev.removeAttribute("src"); prev.classList.add("is-empty"); }
    }
    input.addEventListener("input", sync);
    input.addEventListener("change", sync); // dispatched by the media picker
  });
})();
</script>
}
