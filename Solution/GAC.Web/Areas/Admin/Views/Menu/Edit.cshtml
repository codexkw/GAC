@model GAC.Core.Content.MenuItem
@using GAC.Web.Areas.Admin.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "New menu item" : "Edit menu item";
}
<p><a asp-action="Index">&larr; Back to menu</a></p>

<h1>@(isNew ? "New menu item" : "Edit menu item")</h1>

<form method="post" asp-action="Save">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="adm-error"></div>

    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Label", NameEn = "Label.En", NameAr = "Label.Ar", ValueEn = Model.Label.En, ValueAr = Model.Label.Ar }' />

    <div class="adm-field">
        <label asp-for="Url">Url</label>
        <input asp-for="Url" />
    </div>

    <div class="adm-field">
        <label asp-for="ParentId">Parent</label>
        <select asp-for="ParentId" asp-items="@((List<SelectListItem>)ViewBag.Parents)">
            <option value="">(top level)</option>
        </select>
    </div>

    <div class="adm-field">
        <label asp-for="SortOrder">Sort order</label>
        <input asp-for="SortOrder" type="number" />
    </div>

    <button type="submit" class="adm-btn">Save</button>
</form>
