@model GAC.Core.Content.ContentPage
@using GAC.Web.Areas.Admin.Models
@{
    ViewData["Title"] = "Edit page";
}
<p><a asp-area="Admin" asp-action="Index">&larr; Back to content pages</a></p>

<h1>Edit page</h1>

<form method="post" asp-action="Save">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Slug" />

    <div class="adm-field">
        <label>Slug</label>
        <div>@Model.Slug</div>
    </div>

    <div class="adm-field">
        <label><input asp-for="IsVisible" /> Visible</label>
    </div>

    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Title", NameEn = "Title.En", NameAr = "Title.Ar", ValueEn = Model.Title.En, ValueAr = Model.Title.Ar }' />
    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Meta title", NameEn = "MetaTitle.En", NameAr = "MetaTitle.Ar", ValueEn = Model.MetaTitle.En, ValueAr = Model.MetaTitle.Ar }' />
    <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Meta description", NameEn = "MetaDescription.En", NameAr = "MetaDescription.Ar", ValueEn = Model.MetaDescription.En, ValueAr = Model.MetaDescription.Ar, Multiline = true }' />

    @if (Model.Slug == "warranty")
    {
        <input type="hidden" asp-for="BodyHtml.En" />
        <input type="hidden" asp-for="BodyHtml.Ar" />
        <p class="adm-note">This page's content is edited in <a asp-area="Admin" asp-controller="Warranty" asp-action="Index">Warranty page</a>. Only its title and meta are editable here.</p>
    }
    else if (Model.Slug == "road-assistance")
    {
        <input type="hidden" asp-for="BodyHtml.En" />
        <input type="hidden" asp-for="BodyHtml.Ar" />
        <p class="adm-note">This page's content is edited in <a asp-area="Admin" asp-controller="RoadAssistance" asp-action="Index">Road Assistance</a>. Only its title and meta are editable here.</p>
    }
    else
    {
        <partial name="_LocalizedField" model='new LocalizedFieldModel { Label = "Page body (HTML)", NameEn = "BodyHtml.En", NameAr = "BodyHtml.Ar", ValueEn = Model.BodyHtml.En, ValueAr = Model.BodyHtml.Ar, Code = true }' />
    }

    <button type="submit" class="adm-btn">Save</button>
</form>
